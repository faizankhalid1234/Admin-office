# Admin panel — local
NEXTAUTH_URL="http://localhost:4000"
AUTH_URL="http://localhost:4000"
AUTH_SECRET="your-secret-key-here"
NEXTAUTH_SECRET="your-secret-key-here"
AUTH_TRUST_HOST="true"

# Employee website URL
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3000"
WEBSITE_URL="http://localhost:3000"

# Backend API — port 5000
BACKEND_URL="http://localhost:5000"
NEXT_PUBLIC_BACKEND_URL="http://localhost:5000"

# --- Vercel production (set these in Vercel Dashboard → Settings → Environment Variables) ---
# NEXTAUTH_URL=https://admin-office-nine.vercel.app
# AUTH_URL=https://admin-office-nine.vercel.app
# AUTH_SECRET=<same secret as backend JWT_SECRET>
# NEXTAUTH_SECRET=<same as AUTH_SECRET>
# AUTH_TRUST_HOST=true
# NEXT_PUBLIC_WEBSITE_URL=https://office-website-gilt.vercel.app
# WEBSITE_URL=https://office-website-gilt.vercel.app
# BACKEND_URL=https://backend-office-e.vercel.app
# NEXT_PUBLIC_BACKEND_URL=https://backend-office-e.vercel.app
