# Admin panel — local
NEXTAUTH_URL="http://localhost:4000"
AUTH_URL="http://localhost:4000"
AUTH_SECRET="your-secret-key-here"
NEXTAUTH_SECRET="your-secret-key-here"
AUTH_TRUST_HOST="true"

# Employee website URL
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3000"
WEBSITE_URL="http://localhost:3000"

# Backend API — port 5000 (use 127.0.0.1 on Windows)
BACKEND_URL="http://127.0.0.1:5000"
NEXT_PUBLIC_BACKEND_URL="http://127.0.0.1:5000"
# Optional: used when local backend is not running
BACKEND_FALLBACK_URL="https://backend-office-e.vercel.app"

# Tip: copy this file to .env.local for local dev. Keep production URLs in Vercel Dashboard only.
